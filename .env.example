# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ALLOWED_USER_IDS=123456789  # comma-separated user IDs

# Hyperliquid
HL_PRIVATE_KEY=your_wallet_private_key
HL_WALLET_ADDRESS=your_wallet_address
HL_TESTNET=true  # start on testnet

# Bot Settings
DEFAULT_EXECUTION_MODE=manual  # manual | auto
SCAN_INTERVAL_MINUTES=15
LOG_LEVEL=INFO
DB_PATH=data/bot.db

# Risk Defaults
MAX_POSITION_SIZE=500
MAX_TOTAL_EXPOSURE=2000
MAX_LEVERAGE=5
DEFAULT_SL_PCT=3
DEFAULT_TP_PCT=6
DAILY_LOSS_LIMIT=200
MAX_OPEN_POSITIONS=5
